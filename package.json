{
  "name": "devdash",
  "version": "0.1.0",
  "description": "A personal developer dashboard CLI for Linux, built with TypeScript.",
  "type": "module",
  "bin": {
    "devdash": "./dist/index.js",
    "dsh": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "cli",
    "typescript",
    "linux",
    "productivity"
  ],
  "author": "Sebas",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
